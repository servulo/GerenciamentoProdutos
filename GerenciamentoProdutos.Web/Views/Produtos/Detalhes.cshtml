@model GerenciamentoProdutos.Web.ViewModels.ProdutoViewModel

@{
    ViewBag.Title = "Detalhes do Produto";
}

<h2>Detalhes do Produto</h2>

<dl class="dl-horizontal">
    <dt>Nome</dt>
    <dd>@Model.Nome</dd>
    <dt>Descrição</dt>
    <dd>@Model.Descricao</dd>
    <dt>Preço</dt>
    <dd>@Model.Preco.ToString("C")</dd>
    <dt>Estoque</dt>
    <dd>@Model.QuantidadeEstoque</dd>
</dl>

@Html.ActionLink("Editar", "Editar", new { id = Model.Id }, new { @class = "btn btn-primary" })
@Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-default" })