@model GerenciamentoProdutos.Web.ViewModels.ProdutoViewModel

@{
    ViewBag.Title = "Editar Produto";
}

<h2>Editar Produto</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(m => m.Id)
    @Html.ValidationSummary(true, "Corrija os erros abaixo:")

    <div class="form-group">
        @Html.LabelFor(m => m.Nome)
        @Html.TextBoxFor(m => m.Nome, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Descricao)
        @Html.TextBoxFor(m => m.Descricao, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Descricao, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Preco)
        @Html.TextBoxFor(m => m.Preco, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Preco, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.QuantidadeEstoque)
        @Html.TextBoxFor(m => m.QuantidadeEstoque, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.QuantidadeEstoque, "", new { @class = "text-danger" })
    </div>
    <button type="submit" class="btn btn-success">Salvar</button>
    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
}